                <SelectCommand>
                  <DbCommand CommandType="Text" ModifiedByUser="true">
                    <CommandText>SELECT Cliente.Nombre_cli, Cliente.RUC, Cliente.Direccion_Cli, Cotizacion.Correlativo, Cotizacion.Año, Cotizacion.Fecha, Cotizacion.Valido, Cotizacion.Entrega, Cotizacion.Subtotal, Cotizacion.IGV, Cotizacion.Total, Moneda.Tipo_moneda, 
